rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: jpc_users
    // Fields: id, username, display_name, role, email, leader_id, created_at
    //
    // Collection: jpc_candidates
    // Fields: id, full_name, email, phone, current_stage, created_at, assigned_recruiter
    //
    // Collection: jpc_applications
    // Fields: id, candidate_id, recruiter_id, job_link, applied_at, created_at
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "paramatwork3076@gmail.com" && request.auth.token.email_verified == true) ||
         (get(/databases/$(database)/documents/jpc_users/$(request.auth.uid)).data.role == 'administrator') ||
         (get(/databases/$(database)/documents/jpc_users/$(request.auth.uid)).data.role == 'jpc_sysadmin'));
    }

    function isManager() {
      return isAuthenticated() && get(/databases/$(database)/documents/jpc_users/$(request.auth.uid)).data.role == 'jpc_manager';
    }

    function isRecruiter() {
      return isAuthenticated() && get(/databases/$(database)/documents/jpc_users/$(request.auth.uid)).data.role == 'jpc_recruiter';
    }

    match /jpc_users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /jpc_resume_requests/{requestId} {
      allow read, write: if isAuthenticated();
    }

    match /jpc_candidates/{candidateId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /jpc_applications/{appId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || isManager();
    }

    match /jpc_notifications/{notifId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.recipient_id || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.recipient_id || isAdmin());
      allow delete: if isAdmin();
    }

    match /jpc_report_logs/{logId} {
      allow read, write: if isAuthenticated();
    }

    match /jpc_activity_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /jpc_followups/{followId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /jpc_payments/{paymentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /jpc_promises/{promiseId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /jpc_qc_checklist/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /jpc_interviews/{interviewId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
